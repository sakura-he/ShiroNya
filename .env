# ============================================================
# 公共配置（真正通用，所有环境键和值都一致）
# 只放不会随环境变化的键；任何可能随环境变化的键请放 .env.{NODE_ENV}
# ConfigModule 加载顺序：.env.{NODE_ENV} > .env（前者优先覆盖）
# ============================================================

# ---- 应用基础 ----

# 应用显示名称；出现在 Swagger 标题、默认邮件签名等处
APP_NAME=应用

# app-api HTTP 监听端口；dev/prod 默认都是 3001
APP_API_PORT=3001

# ---- gRPC 服务（app-api AppUserAdmin） ----

# gRPC 服务监听地址；0.0.0.0 表示监听所有网卡
APP_USER_ADMIN_GRPC_HOST=0.0.0.0

# gRPC TLS 证书路径（相对工作目录；容器内通过挂载 certs/ 提供）
APP_USER_ADMIN_GRPC_TLS_CA_PATH=certs/app-user-admin-grpc/ca.crt
APP_USER_ADMIN_GRPC_TLS_SERVER_CERT_PATH=certs/app-user-admin-grpc/server.crt
APP_USER_ADMIN_GRPC_TLS_SERVER_KEY_PATH=certs/app-user-admin-grpc/server.key
APP_USER_ADMIN_GRPC_TLS_CLIENT_CERT_PATH=certs/app-user-admin-grpc/client.crt
APP_USER_ADMIN_GRPC_TLS_CLIENT_KEY_PATH=certs/app-user-admin-grpc/client.key

# gRPC 内部服务账号：app-api 内部服务互调时的身份标识

# ---- Cerbos mTLS 证书路径 ----

# admin-api 独立 Cerbos 客户端证书
ADMIN_CERBOS_TLS_CA_PATH=certs/admin-cerbos-tls/ca.crt
ADMIN_CERBOS_TLS_CLIENT_CERT_PATH=certs/admin-cerbos-tls/client.crt
ADMIN_CERBOS_TLS_CLIENT_KEY_PATH=certs/admin-cerbos-tls/client.key

# app-api 主权限 Cerbos 客户端证书
APP_CERBOS_TLS_CA_PATH=certs/app-cerbos-tls/ca.crt
APP_CERBOS_TLS_CLIENT_CERT_PATH=certs/app-cerbos-tls/client.crt
APP_CERBOS_TLS_CLIENT_KEY_PATH=certs/app-cerbos-tls/client.key

# ---- admin-api Better Auth 内部服务身份 ----

# admin-api 创建系统级审计记录使用的内部账号
ADMIN_BETTER_AUTH_INTERNAL_EMAIL=admin-better-auth-internal@shiro-nya.local
ADMIN_BETTER_AUTH_INTERNAL_NAME=Admin API Internal

# Better Auth Infrastructure；apiUrl / kvUrl 未配置时使用官方默认地址
BETTER_AUTH_API_KEY=ba_replace_me

# ---- SpiceDB 投影消费容错策略（所有环境使用同一阈值） ----

# 同一消息连续失败多少次后暂停消费并写入死信队列
ADMIN_SPICEDB_KAFKA_PROJECTION_CONSUMER_MAX_FAILURES=5
# app-api 使用独立前缀，避免复用 admin 容器变量
APP_SPICEDB_KAFKA_PROJECTION_CONSUMER_MAX_FAILURES=5
