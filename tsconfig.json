{
    "compilerOptions": {
        "module": "esnext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "isolatedModules": true,
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "target": "esnext",
        "sourceMap": true,
        "outDir": "./dist",
        "incremental": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": false,
        "strictBindCallApply": false,
        "noFallthroughCasesInSwitch": false,
        "strict": true,
        "paths": {
            "@app/common": ["./libs/common/src"],
            "@app/common/*": ["./libs/common/src/*"],
            "@app/rbac-core": ["./libs/rbac-core/src"],
            "@app/rbac-core/*": ["./libs/rbac-core/src/*"],
            "@app/cerbos": ["./libs/cerbos"],
            "@app/cerbos/*": ["./libs/cerbos/*"],
            "@app/cerbos-abac": ["./libs/cerbos-abac/src"],
            "@app/cerbos-abac/*": ["./libs/cerbos-abac/src/*"],
            "@app/mongodb": ["./libs/mongodb/src"],
            "@app/mongodb/*": ["./libs/mongodb/src/*"],
            "@utils/*": ["./libs/common/src/utils/*"],
            "@decorators/*": ["./libs/common/src/decorators/*"],
            "@filters/*": ["./libs/common/src/filters/*"],
            "@app/prisma-admin": ["./libs/prisma-admin/src"],
            "@app/prisma-admin/*": ["./libs/prisma-admin/src/*"],
            "@app/prisma-app": ["./libs/prisma-app/src"],
            "@app/prisma-app/*": ["./libs/prisma-app/src/*"]
        }
    },
    "files": ["./global.d.ts"]
}
