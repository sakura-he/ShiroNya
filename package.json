    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.(spec|test)\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": [
                "ts-jest",
                {
                    "tsconfig": {
                        "module": "commonjs",
                        "moduleResolution": "node"
                    }
                }
            ]
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/apps/",
            "<rootDir>/libs/"
        ],
        "moduleNameMapper": {
            "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
            "^@app/rbac-core(|/.*)$": "<rootDir>/libs/rbac-core/src/$1",
            "^@app/cerbos(|/.*)$": "<rootDir>/libs/cerbos/$1",
            "^@app/cerbos-abac(|/.*)$": "<rootDir>/libs/cerbos-abac/src/$1",
            "^@app/mongodb(|/.*)$": "<rootDir>/libs/mongodb/src/$1",
            "^@utils/(.*)$": "<rootDir>/libs/common/src/utils/$1",
            "^@decorators/(.*)$": "<rootDir>/libs/common/src/decorators/$1",
            "^@filters/(.*)$": "<rootDir>/libs/common/src/filters/$1",
            "^@/(.*)$": "<rootDir>/apps/app-api/src/$1",
            "^@app/prisma-admin(|/.*)$": "<rootDir>/libs/prisma-admin/src/$1",
            "^@app/prisma-app(|/.*)$": "<rootDir>/libs/prisma-app/src/$1"
        }
    },
    "packageManager": "pnpm@9.15.2+sha512.93e57b0126f0df74ce6bff29680394c0ba54ec47246b9cf321f0121d8d9bb03f750a705f24edc3c1180853afd7c2c3b94196d0a3d53d3e069d9e2793ef11f321"
}
