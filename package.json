    "type": "module",
    "scripts": {
        "start:admin-api:dev": "nest start admin-api --watch",
        "start:app-api:dev": "nest start app-api --watch",
        "prisma:studio": "pnpm prisma:admin:studio",
        "prisma:generate": "pnpm prisma:generate:split",
        "prisma:push": "pnpm prisma:push:split",
        "authz:inspect": "npx tsx scripts/inspect-authz-state.ts",
        "authz:verify:runtime": "pnpm spicedb:admin:schema:validate && pnpm authz:inspect",
        "authz:sync:admin-api-managers": "npx tsx scripts/sync-admin-api-manager-authz.ts",
        "rbac:seed": "npx tsx scripts/seed-admin-api-rbac.ts",
        "start:admin-web:dev": "pnpm --filter ./apps/admin-web dev",
        "build:admin-web": "pnpm --filter ./apps/admin-web build",
        "build:admin-api": "nest build admin-api",
        "build:app-api": "nest build app-api",
        "start:admin-api": "nest start admin-api",
        "start:admin-api:prod": "node dist/apps/admin-api/main.js",
        "start:app-api": "nest start app-api",
        "start:app-api:prod": "node dist/apps/app-api/main.js",
        "spicedb:admin:schema:validate": "pnpm exec zed validate spicedb/schema.zed",
        "spicedb:admin:schema:read": "pnpm exec zed schema read",
        "spicedb:admin:schema:write": "pnpm exec zed schema write spicedb/schema.zed",
        "clean": "node -e \"const fs=require('fs');['dist','coverage'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}))\"",
        "clean:runtime": "node -e \"const fs=require('fs');['logs','.tmp'].forEach((p)=>fs.rmSync(p,{recursive:true,force:true}))\"",
        "deploy": "pnpm --filter @shiro-nya/deploy-kit run deploy",
        "deploy-script:build": "pnpm --filter @shiro-nya/deploy-kit run build",
        "deploy-script:release": "node scripts/package-deploy-release.mjs",
        "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"scripts/**/*.ts\"",
        "lint": "eslint \"{apps,libs,scripts}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "rbac:seed:app-api": "npx tsx scripts/seed-app-api-rbac.ts",
        "prisma:admin:studio": "npx prisma studio --config ./prisma.admin.config.ts",
        "prisma:app:studio": "npx prisma studio --config ./prisma.app.config.ts",
        "prisma:admin:generate": "npx prisma generate --config ./prisma.admin.config.ts",
        "prisma:app:generate": "npx prisma generate --config ./prisma.app.config.ts",
        "prisma:admin:push": "npx prisma db push --config ./prisma.admin.config.ts",
        "prisma:app:push": "npx prisma db push --config ./prisma.app.config.ts",
        "prisma:generate:split": "pnpm prisma:admin:generate && pnpm prisma:app:generate",
        "prisma:push:split": "pnpm prisma:admin:push && pnpm prisma:app:push"
    },
