model SpiceDbUserGroupMemberProjection {
  /// 后台用户 ID，对应 Better Auth 用户主键
  userId    String   @map("user_id") @db.VarChar(191)
  /// 用户组 ID，对应 shiro_user_group.id
  groupId   Int      @map("group_id")
  /// 最后同步到当前关系的 SpiceDB ZedToken
  zedToken  String?  @map("zed_token") @db.Text
  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([userId, groupId])
  @@index([groupId])
  @@map("spicedb_user_group_member_projection")
}

model SpiceDbUserRoleProjection {
