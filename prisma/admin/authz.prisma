  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@id([userId, roleId])
  @@index([roleId])
  @@map("spicedb_user_role_projection")
}

model SpiceDbUserGroupRoleProjection {
  /// 用户组 ID，对应 shiro_user_group.id
  groupId   Int      @map("group_id")
  /// 角色 ID，对应 shiro_role.id
  roleId    Int      @map("role_id")
  /// 最后同步到当前关系的 SpiceDB ZedToken
  zedToken  String?  @map("zed_token") @db.Text
  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at")
