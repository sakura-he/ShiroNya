{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "monorepo": true,
    "root": "apps/admin-api",
    "sourceRoot": "apps/admin-api/src",
    "compilerOptions": {
        "deleteOutDir": true,
        "webpack": true,
        "webpackConfigPath": "webpack.config.cjs"
    },
    "projects": {
        "common": {
            "type": "library",
            "root": "libs/common",
            "entryFile": "index",
            "sourceRoot": "libs/common/src",
            "compilerOptions": {
                "tsConfigPath": "libs/common/tsconfig.lib.json"
            }
        },
        "app-api": {
            "type": "application",
            "root": "apps/app-api",
            "entryFile": "main",
            "sourceRoot": "apps/app-api/src",
            "compilerOptions": {
                "tsConfigPath": "apps/app-api/tsconfig.app.json"
            }
        },
        "rbac-core": {
            "type": "library",
            "root": "libs/rbac-core",
            "entryFile": "index",
            "sourceRoot": "libs/rbac-core/src",
            "compilerOptions": {
                "webpack": false,
                "tsConfigPath": "libs/rbac-core/tsconfig.lib.json"
            }
        },
        "cerbos": {
            "type": "library",
            "root": "libs/cerbos",
            "entryFile": "index",
            "sourceRoot": "libs/cerbos",
            "compilerOptions": {
                "tsConfigPath": "libs/cerbos/tsconfig.lib.json"
            }
        },
        "cerbos-abac": {
            "type": "library",
            "root": "libs/cerbos-abac",
            "entryFile": "index",
            "sourceRoot": "libs/cerbos-abac/src",
            "compilerOptions": {
                "tsConfigPath": "libs/cerbos-abac/tsconfig.lib.json"
            }
        },
        "mongodb": {
            "type": "library",
            "root": "libs/mongodb",
            "entryFile": "index",
            "sourceRoot": "libs/mongodb/src",
            "compilerOptions": {
                "tsConfigPath": "libs/mongodb/tsconfig.lib.json"
            }
        },
        "admin-api": {
            "type": "application",
            "root": "apps/admin-api",
            "entryFile": "main",
            "sourceRoot": "apps/admin-api/src",
            "compilerOptions": {
                "plugins": [
                    {
                        "name": "@nestjs/swagger",
                        "options": {
                            "classValidatorShim": true,
                            "introspectComments": true,
                            "esmCompatible": true
                        }
                    }
                ],
                "tsConfigPath": "apps/admin-api/tsconfig.app.json"
            }
        },
        "prisma-admin": {
            "type": "library",
            "root": "libs/prisma-admin",
            "entryFile": "index",
            "sourceRoot": "libs/prisma-admin/src",
            "compilerOptions": {
                "tsConfigPath": "libs/prisma-admin/tsconfig.lib.json"
            }
        },
        "prisma-app": {
            "type": "library",
            "root": "libs/prisma-app",
            "entryFile": "index",
            "sourceRoot": "libs/prisma-app/src",
            "compilerOptions": {
                "tsConfigPath": "libs/prisma-app/tsconfig.lib.json"
            }
        }
    }
}
