{
  "name": "@spicedb-toolkit/core",
  "version": "0.1.0",
  "description": "Type-safe SpiceDB client toolkit for Node.js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@authzed/authzed-node": "^1.6.1",
    "@authzed/spicedb-parser-js": "^1.1.0",
    "@opentelemetry/api": "^1.9.1",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "spicedb",
    "authzed",
    "authorization",
    "permissions",
    "zanzibar"
  ],
  "license": "MIT"
}
