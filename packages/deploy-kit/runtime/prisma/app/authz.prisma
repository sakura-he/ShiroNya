model SpiceDbProjectionEventLog {
  id               Int       @id @default(autoincrement())
  topic            String    @db.VarChar(191)
  partition        Int
  offset           String    @db.VarChar(191)
  eventKey         String    @map("event_key") @db.VarChar(255)
  zedToken         String?   @map("zed_token") @db.Text
  operation        String?   @db.VarChar(191)
  status           String    @db.VarChar(32)
  reason           String?   @db.Text
  error            String?   @db.Text
  payload          Json?
  handledAt        DateTime? @map("handled_at")
  handledBy        String?   @map("handled_by") @db.VarChar(191)
  handledReason    String?   @map("handled_reason") @db.Text
  replayCount      Int       @default(0) @map("replay_count")
  lastReplayAt     DateTime? @map("last_replay_at")
  lastReplayBy     String?   @map("last_replay_by") @db.VarChar(191)
  lastReplayStatus String?   @map("last_replay_status") @db.VarChar(32)
  lastReplayError  String?   @map("last_replay_error") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@unique([topic, partition, offset])
  @@index([eventKey])
  @@index([status, createdAt])
  @@index([handledAt])
  @@index([zedToken])
  @@map("spicedb_projection_event_log")
}

model SpiceDbSchemaPublication {
  id                 String   @id @db.VarChar(32)
  version            Int
  schemaHash         String   @map("schema_hash") @db.VarChar(64)
  previousSchemaHash String?  @map("previous_schema_hash") @db.VarChar(64)
  schemaText         String   @map("schema_text") @db.Text
  diffText           String   @map("diff_text") @db.Text
  publishedBy        String   @map("published_by") @db.VarChar(191)
  publishedAt        DateTime @default(now()) @map("published_at")
  reason             String   @db.Text
  status             String   @db.VarChar(32)
  zedToken           String?  @map("zed_token") @db.Text
  error              String?  @db.Text
  rollbackHint       String?  @map("rollback_hint") @db.Text
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([version])
  @@index([schemaHash])
  @@index([status, publishedAt])
  @@map("spicedb_schema_publication")
}

model SpiceDbProjectionCursor {
  id              Int       @id @default(autoincrement())
  topic           String    @db.VarChar(191)
  partition       Int
  consumerGroup   String    @map("consumer_group") @db.VarChar(191)
  lastOffset      String?   @map("last_offset") @db.VarChar(191)
  lastEventKey    String?   @map("last_event_key") @db.VarChar(255)
  lastZedToken    String?   @map("last_zed_token") @db.Text
  lastEventAt     DateTime? @map("last_event_at")
  lastProcessedAt DateTime? @map("last_processed_at")
  lag             BigInt    @default(0)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  @@unique([topic, partition, consumerGroup])
  @@index([lastProcessedAt])
  @@map("spicedb_projection_cursor")
}

model SpiceDbProjectionReconcileRun {
  id                    String    @id @db.VarChar(32)
  mode                  String    @db.VarChar(32)
  triggeredBy           String    @map("triggered_by") @db.VarChar(64)
  reason                String    @db.Text
  status                String    @db.VarChar(32)
  zedToken              String?   @map("zed_token") @db.Text
  startedAt             DateTime  @default(now()) @map("started_at")
  finishedAt            DateTime? @map("finished_at")
  durationMs            Int?      @map("duration_ms")
  userGroupMembersStats Json?     @map("user_group_members_stats")
  userRolesStats        Json?     @map("user_roles_stats")
  userGroupRolesStats   Json?     @map("user_group_roles_stats")
  menuRolesStats        Json?     @map("menu_roles_stats")
  totalStats            Json?     @map("total_stats")
  error                 String?   @db.Text
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([status, startedAt])
  @@index([mode, startedAt])
  @@map("spicedb_projection_reconcile_run")
}
