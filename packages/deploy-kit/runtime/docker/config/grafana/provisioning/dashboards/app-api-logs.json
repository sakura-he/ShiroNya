{
  "uid": "app-api-logs",
  "title": "App API 日志中心",
  "description": "App API (app-api) 全量日志分析 — 系统日志 + 用户操作日志",
  "tags": [
    "shiro-nya",
    "app-api",
    "logs",
    "system",
    "user-action"
  ],
  "timezone": "Asia/Shanghai",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "← 服务总览",
      "type": "link",
      "icon": "dashboard",
      "url": "/d/shiro-nya-overview",
      "targetBlank": false
    },
    {
      "title": "Admin API 日志",
      "type": "link",
      "icon": "apps",
      "url": "/d/admin-api-logs",
      "targetBlank": false
    },
    {
      "title": "Cerbos 权限审计",
      "type": "link",
      "icon": "shield",
      "url": "/d/shiro-nya-cerbos-audit",
      "targetBlank": false
    },
    {
      "title": "Explore",
      "type": "link",
      "icon": "compass",
      "url": "/explore?left={\"datasource\":\"loki\",\"queries\":[{\"expr\":\"{app=\\\"app-api\\\"}\"}]}",
      "targetBlank": true
    },
    {
      "title": "查询中心",
      "type": "link",
      "icon": "search",
      "url": "/d/shiro-nya-query-center",
      "tooltip": "集中查看常用 Loki 查询面板",
      "targetBlank": false
    }
  ],
  "annotations": {
    "list": [
      {
        "name": "错误事件",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "iconColor": "red",
        "expr": "count_over_time({app=\"app-api\", level=\"error\"} [1m])",
        "titleFormat": "App API Error",
        "tagKeys": "level,module"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "log_type",
        "label": "日志类型",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": {
          "type": 1,
          "label": "log_type",
          "stream": "{app=\"app-api\"}"
        },
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": true
      },
      {
        "name": "level",
        "label": "级别",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": {
          "type": 1,
          "label": "level",
          "stream": "{app=\"app-api\"}"
        },
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": true
      },
      {
        "name": "module",
        "label": "模块",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": {
          "type": 1,
          "label": "module",
          "stream": "{app=\"app-api\"}"
        },
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": true
      },
      {
        "name": "user_id",
        "label": "用户ID",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": {
          "type": 1,
          "label": "user_id",
          "stream": "{app=\"app-api\"}"
        },
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "📊 全局指标",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "总日志量",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"app-api\", log_type=~\"$log_type\", level=~\"$level\", module=~\"$module\"} [$__range]))",
          "legendFormat": ""
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        }
      }
    },
    {
