{
  "uid": "shiro-nya-overview",
  "title": "Shiro Nya 服务总览",
  "description": "全局服务健康监控看板，聚合运行时日志与关键指标",
  "tags": [
    "shiro-nya",
    "overview",
    "monitoring",
    "enterprise"
  ],
  "timezone": "Asia/Shanghai",
  "editable": true,
  "graphTooltip": 2,
  "refresh": "30s",
  "schemaVersion": 39,
  "links": [
    {
      "title": "App API 日志",
      "type": "link",
      "icon": "apps",
      "url": "/d/app-api-logs",
      "tooltip": "App API 日志中心"
    },
    {
      "title": "Admin API 日志",
      "type": "link",
      "icon": "cog",
      "url": "/d/admin-api-logs",
      "tooltip": "Admin API 日志中心"
    },
    {
      "title": "Tempo 链路追踪",
      "type": "link",
      "icon": "compass",
      "url": "/d/shiro-nya-tempo-traces",
      "tooltip": "Shiro Nya Tempo 链路追踪"
    },
    {
      "title": "Admin API 请求排查",
      "type": "link",
      "icon": "search",
      "url": "/d/admin-api-request-drilldown",
      "tooltip": "按用户、request_id、接口路径排查请求",
      "targetBlank": false
    },
    {
      "title": "查询中心",
      "type": "link",
      "icon": "search",
      "url": "/d/shiro-nya-query-center",
      "tooltip": "集中查看常用 Loki 查询面板",
      "targetBlank": false
    }
  ],
  "annotations": {
    "list": [
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{job=~\"shiro-nya.*\", level=~\"error|fatal\"} |= \"\"",
        "iconColor": "red",
        "name": "错误事件",
        "titleFormat": "{{app}} {{module}}",
        "tagKeys": "level,app"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "name": "app",
        "query": {
          "label": "app",
          "stream": "{job=~\"shiro-nya.*\"}",
          "type": 1
        },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "🏠 健康指标",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "运行时日志总量",
      "description": "选定时间范围内的运行时日志总数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "错误日志",
      "description": "error + fatal 级别日志数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=~\"shiro-nya.*\", app=~\"$app\", level=~\"error|fatal\"} [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "title": "系统日志",
      "description": "log_type=system 日志数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=~\"shiro-nya.*\", app=~\"$app\", log_type=\"system\"} [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "super-light-blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "title": "用户操作日志",
      "description": "log_type=user_action 日志数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({job=~\"shiro-nya.*\", app=~\"$app\", log_type=\"user_action\"} [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "super-light-green",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "活跃模块数",
      "description": "产生日志的模块总数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "count(count by (module) (count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__range])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "last"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "📈 日志趋势",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "日志速率 · 按级别",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 80
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "fatal"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "dark-red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "debug"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "verbose"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "light-blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "日志速率 · 按应用",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (app) (count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__auto]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 80
          },
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "📊 分类分布",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "collapsed": false
    },
    {
      "id": 9,
      "title": "应用分布",
      "type": "piechart",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (app) (count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__range]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "legend": {
          "placement": "right",
          "displayMode": "table",
          "calcs": [
            "percent"
          ]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 13,
      "title": "日志类型占比",
      "type": "piechart",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 6,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (log_type) (count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__range]))",
          "legendFormat": "{{log_type}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "legend": {
          "placement": "right",
          "displayMode": "table",
          "calcs": [
            "percent"
          ]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 10,
      "title": "日志级别占比",
      "type": "piechart",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__range]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "debug"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warn"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "legend": {
          "placement": "right",
          "displayMode": "table",
          "calcs": [
            "percent"
          ]
        },
        "pieType": "donut"
      }
    },
    {
      "id": 11,
      "title": "模块活跃度 Top 10",
      "type": "bargauge",
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (module) (count_over_time({job=~\"shiro-nya.*\", app=~\"$app\"} [$__range])))",
          "legendFormat": "{{module}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 103,
      "type": "row",
      "title": "🔴 最近错误",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      },
      "collapsed": false
    },
    {
      "id": 12,
      "title": "错误日志流",
      "description": "仅显示 error/fatal 级别的日志",
      "type": "logs",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=~\"shiro-nya.*\", app=~\"$app\", level=~\"error|fatal\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "enableHighlighting": true,
        "fontSize": "default",
        "sortOrder": "Descending"
      }
    }
  ],
  "version": 1
}
