    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP 状态码趋势",
      "description": "按 http.status_code 拆分入口 span 速率，适合快速看 4xx/5xx 是否出现",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{resource.service.name=\"$service\" && span.http.status_code >= 100} | rate() by (span.http.status_code)",
          "metricsQueryType": "range",
          "step": "30s",
          "exemplars": 20,
          "legendFormat": "{{span.http.status_code}}",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "filters": [],
          "groupBy": []
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "custom": {
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "fillOpacity": 70,
            "lineWidth": 1,
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "/4..|5../"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
