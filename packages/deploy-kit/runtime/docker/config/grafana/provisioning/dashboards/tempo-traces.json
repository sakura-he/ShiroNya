    {
      "id": 1,
      "type": "stat",
      "title": "总 Span 速率",
      "description": "选定服务在当前时间窗口内的 span 吞吐，单位为每秒 span 数",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{resource.service.name=\"$service\"} | rate()",
          "metricsQueryType": "range",
          "step": "30s",
          "exemplars": 10,
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "filters": [],
          "groupBy": []
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
