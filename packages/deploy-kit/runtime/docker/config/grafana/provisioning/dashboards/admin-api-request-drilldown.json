    {
      "id": 12,
      "type": "timeseries",
      "title": "接口 P95/P99 趋势",
      "description": "按接口 route 分组展示 P95/P99；路径多时建议把 endpoint_regex 缩小。",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "P95",
          "expr": "quantile_over_time(0.95, {app=\"$service\", log_type=\"user_action\"} | json http_route=\"http.route\", duration_ms=\"http.durationMs\" | http_route=~\"$endpoint_regex\" | unwrap duration_ms [$__interval]) by (http_route)",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "P95 {{http_route}}"
        },
        {
          "refId": "P99",
          "expr": "quantile_over_time(0.99, {app=\"$service\", log_type=\"user_action\"} | json http_route=\"http.route\", duration_ms=\"http.durationMs\" | http_route=~\"$endpoint_regex\" | unwrap duration_ms [$__interval]) by (http_route)",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "legendFormat": "P99 {{http_route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "接口请求量趋势",
      "description": "按接口 route 分组展示请求量，用来判断慢是否由流量尖峰引起。",
      "gridPos": {
