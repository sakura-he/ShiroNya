    {
      "id": 300,
      "type": "row",
      "title": "按接口路径查耗时",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "stat",
      "title": "接口请求数",
      "description": "endpoint_regex 范围内的 user_action 请求数。",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"$service\", log_type=\"user_action\"} | json http_route=\"http.route\" | http_route=~\"$endpoint_regex\" [$__range]))",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "接口 P95 ms",
      "description": "endpoint_regex 范围内 HTTP 完成日志的 P95 耗时。",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 24
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "quantile_over_time(0.95, {app=\"$service\", log_type=\"user_action\"} | json http_route=\"http.route\", duration_ms=\"http.durationMs\" | http_route=~\"$endpoint_regex\" | unwrap duration_ms [$__range])",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
