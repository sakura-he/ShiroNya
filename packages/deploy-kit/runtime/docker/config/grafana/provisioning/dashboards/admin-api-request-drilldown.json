          "expr": "sum(count_over_time({app=\"$service\", log_type=\"user_action\"} | json http_route=\"http.route\", duration_ms=\"http.durationMs\" | http_route=~\"$endpoint_regex\" | duration_ms >= $slow_ms [$__range]))",
