    {
      "id": 4,
      "type": "table",
      "title": "用户关联 Trace",
      "description": "新镜像发布后，认证/授权 span 会写入 span.shiro.user_id，可直接按用户找链路耗时。",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "refId": "A",
          "queryType": "traceql",
          "query": "{resource.service.name=\"$service\" && span.shiro.user_id=~\"$user_id\"}",
          "limit": 20,
          "tableType": "traces",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "filters": [],
          "groupBy": []
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      }
    },
    {
