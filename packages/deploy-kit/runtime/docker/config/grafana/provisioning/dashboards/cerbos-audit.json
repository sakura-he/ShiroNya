{
  "uid": "shiro-nya-cerbos-audit",
  "title": "Cerbos 权限审计",
  "description": "Cerbos PDP 权限引擎审计日志 — 追踪 API 访问决策、资源授权、拒绝事件、主体行为分析",
  "tags": [
    "shiro-nya",
    "cerbos",
    "audit",
    "security",
    "authorization",
    "rbac"
  ],
  "timezone": "Asia/Shanghai",
  "editable": true,
  "graphTooltip": 2,
  "refresh": "30s",
  "schemaVersion": 39,
  "links": [
    {
      "title": "← 服务总览",
      "type": "link",
      "icon": "home-alt",
      "url": "/d/shiro-nya-overview"
    },
    {
      "title": "App API 日志",
      "type": "link",
      "icon": "apps",
      "url": "/d/app-api-logs"
    },
    {
      "title": "Admin API 日志",
      "type": "link",
      "icon": "cog",
      "url": "/d/admin-api-logs"
    },
    {
      "title": "Explore",
      "type": "link",
      "icon": "compass",
      "url": "/explore",
      "targetBlank": true
    },
    {
      "title": "查询中心",
      "type": "link",
      "icon": "search",
      "url": "/d/shiro-nya-query-center",
      "tooltip": "集中查看常用 Loki 查询面板",
      "targetBlank": false
    }
  ],
  "annotations": {
    "list": [
      {
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "expr": "{service_name=\"cerbos-audit\"} |~ \"EFFECT_DENY\"",
        "iconColor": "orange",
        "name": "拒绝事件",
        "titleFormat": "DENY: {{principal_id}} → {{resource_kind}}",
        "tagKeys": "kind,principal_id,resource_kind"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "name": "kind",
        "query": {
          "label": "kind",
          "stream": "{service_name=\"cerbos-audit\"}",
          "type": 1
        },
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {},
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "name": "principal_id",
        "query": {
          "label": "principal_id",
          "stream": "{service_name=\"cerbos-audit\"}",
          "type": 1
        },
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {},
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "name": "resource_kind",
        "query": {
          "label": "resource_kind",
          "stream": "{service_name=\"cerbos-audit\"}",
          "type": 1
        },
        "refresh": 2,
        "type": "query"
      },
      {
        "current": {},
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "includeAll": true,
        "multi": true,
        "name": "method",
        "query": {
          "label": "method",
          "stream": "{service_name=\"cerbos-audit\"}",
          "type": 1
        },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 400,
      "type": "row",
      "title": "🛡️ 审计指标",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "审计事件总数",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"cerbos-audit\", kind=~\"$kind\", principal_id=~\"$principal_id\", resource_kind=~\"$resource_kind\", method=~\"$method\"} [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "sum"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
